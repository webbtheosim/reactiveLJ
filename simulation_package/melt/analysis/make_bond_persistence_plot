DEFAULT_CONDITIONS: Tuple[Tuple[float, float], ...] = (
    (18.0, 2.0),
    (18.0, 4.0),
    (18.0, 8.0),
)
DEFAULT_WEAKENING_EXPONENT = 4.0
FALLBACK_TAU_R0 = 4041.0
MAX_ANALYSIS_LAG_TAU_R0 = 1000.0
MAX_ANALYSIS_LAG_TIME = FALLBACK_TAU_R0 * MAX_ANALYSIS_LAG_TAU_R0
BAR_COLOR = "#e77500"
EDGE_COLOR = "#121212"
